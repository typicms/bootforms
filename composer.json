{
    "name": "typicms/bootforms",
    "description": "Just a Formbuilder with some Bootstrap 5 specific conveniences. Remembers old input, retrieves error messages and handles all your boilerplate Bootstrap markup automatically.",
    "authors": [
        {
            "name": "Adam Wathan",
            "email": "adam.wathan@gmail.com"
        },
        {
            "name": "Samuel De Backer",
            "email": "sdebacker@gmail.com"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "typicms/form": "^4.0.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TypiCMS\\BootForms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TypiCMS\\BootForms\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "laravel": {
            "providers": [
                "TypiCMS\\BootForms\\BootFormsServiceProvider"
            ],
            "aliases": {
                "BootForm": "TypiCMS\\BootForms\\Facades\\BootForm"
            }
        }
    }
}
